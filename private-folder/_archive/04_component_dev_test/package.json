{
  "name": "chord-ds-component-dev-test",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prestorybook": "npm run tokens:build",
    "storybook": "npm run build-storybook && python3 -m http.server 7007 -d storybook-static",
    "prebuild-storybook": "npm run tokens:build",
    "build-storybook": "storybook build",
    "tokens:build": "node scripts/build-tokens.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "npm run tokens:build && tsc --noEmit && vite build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^6.4.2",
    "typescript": "^5.9.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.2.0",
    "storybook": "8.6.18",
    "vitest": "^4.0.15"
  }
}
