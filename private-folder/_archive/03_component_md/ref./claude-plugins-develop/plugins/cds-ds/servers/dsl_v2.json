{
  "$schema": "cds-ds/dsl/v2",
  "description": "Weverse DS DSL v2 — Figma 뷰를 구조적 Node 트리로 표현하고, DS 카탈로그(cds-catalogs) 매핑·레이아웃·스타일·텍스트·에셋을 분리해 기술한다. 토큰 참조 문법·다축 variant·slot 매핑은 cds-catalogs 출력 형식을 그대로 따른다.",

  "fields": {
    "schemaVersion": "DSL 스키마 버전. 현재 '2.0.0'",
    "metadata": "생성 정보·원본 파일 정보. Metadata 타입 참조 (required)",
    "coordinateSystem": "좌표계 정의. CoordinateSystem 타입 참조 (required)",
    "themes": "테마/모드 축 선언 (optional). 색·사이즈는 ['light','dark'], 타이포는 ['ios','aos','web','mode-1']과 같이 카탈로그 modes를 따른다",
    "platform": "대상 플랫폼 (optional). 'ios' | 'android' | 'web'",
    "dsManifest": "DSL 생성 시 적용된 매니페스트 스냅샷 (optional). { platform, tokens: [...], components: [...] }",
    "nodes": "최상위 Node 목록 (required, 비어있지 않음)"
  },

  "rules": {
    "type_selection": [
      "Figma FRAME with auto-layout → Node.type = 'stack', layout.kind = 'stack', layout.axis 결정",
      "Figma FRAME without auto-layout (절대 좌표) → Node.type = 'frame', layout.kind = 'absolute' 또는 'box'",
      "Figma INSTANCE 또는 COMPONENT → Node.type = 'component', catalog 필수",
      "Figma TEXT → Node.type = 'text', text 필드 필수",
      "Figma 이미지/아이콘(RECTANGLE with image fill, VECTOR) → Node.type = 'image', asset 필수",
      "Figma GROUP → Node.type = 'group' (레이아웃 의미 없음, 단순 묶음)"
    ],
    "catalog_mapping": [
      "Figma INSTANCE이고 main component가 cds-catalogs(ds_list().components)에 존재 → catalog 필수",
      "이름 매칭으로 추정될 때(예: 'BadgeNew' → badge) → catalog.id 채우고 catalog.fallback에 raw 노드 표현도 함께 기록",
      "매핑 실패 → catalog 생략, Node.type = 'frame'/'group' + style 직접 기술",
      "catalog.id는 ds_list 반환값(예: 'textbutton') — 소문자, kebab/연속소문자",
      "catalog.componentId는 카탈로그 파일 내부 id(예: 'component:text-button') — id가 명확할 때만"
    ],
    "variant_resolution": [
      "Figma componentProperties → catalog.variant 객체로 그대로 보존(단일 axis도 객체로 작성)",
      "axes 값은 절대 정규화하지 않는다. 카탈로그 axes 배열의 문자열을 byte-exact 복사: 공백·괄호·한국어·대소문자·언더스코어·숫자 모두 보존 (예: 'Large(44)', 'Default (Gray Ghost 단일컬러)', 'Outlined_color')",
      "DS 카탈로그 axes 정의에 없는 키는 드롭",
      "Figma 값과 카탈로그 axes 값이 정확히 일치하지 않으면 추론으로 채우지 말고 해당 axis를 생략한다"
    ],
    "slot_assignment": [
      "INSTANCE 자식 → catalog.slots에 component slot id로 매핑(slot type='instance')",
      "TEXT 자식 → 텍스트 슬롯(label/title/subtitle 등, slot type='text')",
      "leading 위치(왼쪽/위) → leading 또는 leading-icon",
      "trailing 위치(오른쪽/아래) → trailing 또는 trailing-icon",
      "메인 텍스트 → label / title / content (카탈로그 slot 정의 우선)",
      "required slot이 비어 있으면 카탈로그 정의의 default 값을 채운다"
    ],
    "token_reference_syntax": [
      "DS 토큰: 'token:<dotted.path>' (예: 'token:system.color.button.default')",
      "리터럴 값: 'hardcoded:<value>' (예: 'hardcoded:rgba(255,255,255,0)')",
      "매칭 실패 raw 값: 'unresolved:<value>' (예: 'unresolved:#484848')",
      "복합 텍스트 스타일: 'textStyle:<name>' (예: 'textStyle:body-lg/system-700')",
      "Slashed name 경로(예: 'system/color/button/hover')는 component 정의의 diffFromDefault 등에서만 사용. DSL fill/stroke/textStyle 필드는 dotted id 형식을 우선 사용한다"
    ],
    "required_fields": [
      "Root: schemaVersion, metadata, coordinateSystem, nodes",
      "Node: id, type, name",
      "Node(type='text'): text.value (textStyle 또는 typography 중 하나 이상 권장)",
      "Node(type='image'|'icon'): asset.kind 와 asset.ref 또는 asset.url",
      "Node(type='component'): catalog.id (variant·props·slots 는 axes/props/slots 정의 따라 채움)",
      "Catalog: id (그 외는 카탈로그 정의 따름)"
    ],
    "omission_policy": [
      "기본값과 동일한 옵셔널 필드는 생략(예: opacity=1.0)",
      "modes 별 차이 없을 때 themes 생략",
      "layout.frame은 디버깅·오버라이드용. positioning='flow'면 생략 가능"
    ]
  },

  "types": {
    "Metadata": {
      "generatedAt": "ISO 8601 시각",
      "generator": "변환기 식별자(예: 'cds-ds@2.0.0')",
      "sourceFile": "{ fileKey, fileName, nodeId, lastModified }",
      "originHash": "원본 추적 해시"
    },
    "CoordinateSystem": {
      "unit": "'px' | 'pt' | 'dp'",
      "origin": "'topLeft' | 'topRight' | 'bottomLeft' | 'bottomRight' | 'center'",
      "scope": "'relativeToParent' | 'absolute'",
      "scale": "원본 대비 스케일 (number, 1.0 기준)"
    },
    "Node": {
      "id": "DSL 트리 내 고유 id",
      "type": "'frame' | 'stack' | 'group' | 'text' | 'image' | 'icon' | 'component' | 'shape'",
      "name": "원본 노드 이름",
      "source": "Source 타입 참조 (optional)",
      "catalog": "Catalog 타입 참조 (type='component'일 때 필수)",
      "layout": "Layout 타입 참조 (optional)",
      "style": "Style 타입 참조 (optional)",
      "text": "Text 타입 참조 (type='text'일 때 필수)",
      "asset": "Asset 타입 참조 (type='image'|'icon'일 때 필수)",
      "children": "하위 Node 배열 (재귀, optional)"
    },
    "Source": {
      "figmaNodeId": "원본 Figma node id",
      "componentId": "Figma component id",
      "instanceId": "Figma instance id",
      "originNodeId": "변환 전 노드 id",
      "originPath": "원본 트리 경로(슬래시 또는 ' > ')",
      "originHash": "노드 원본 해시"
    },
    "Catalog": {
      "id": "카탈로그 컴포넌트 ID. ds_list().components 반환값과 일치. 예: 'textbutton', 'badge', 'list', 'listItem', 'button' (required)",
      "type": "카탈로그 내부 세부 타입. id가 family 단위일 때 하위 분류를 표현. 예: 'statusBadge', 'thumbnailListItem' (optional)",
      "componentId": "카탈로그 파일 내부 component id. 예: 'component:text-button' (optional)",
      "variant": "DS variant. 카탈로그 axes 정의 키→값 객체. 단축이면 객체 1키, 다축이면 N키. 예: { Type: 'Filled', Size: 'Large(44)', Status: 'Default' } (optional)",
      "version": "카탈로그 스펙 버전. 예: 'v0.2-draft' (optional)",
      "props": "CatalogProps 타입 참조 — 카탈로그 컴포넌트에 주입할 프로퍼티 (optional)",
      "slots": "CatalogSlots 타입 참조 — children을 의미 있는 슬롯에 매핑 (optional)",
      "state": "상태값. 'enabled' | 'disabled' | 'pressed' | 'hover' | 'focused' | 'loading' | 'selected' | 'default' (optional)",
      "fallback": "catalog 매핑 실패 시 사용할 일반 Node 렌더링 정보. 부분 Node 구조 (optional)"
    },
    "CatalogProps": {
      "_doc": "카탈로그 컴포넌트의 props 정의를 따른다. 아래 키들은 도메인 표준(canonical) prop 이름이며, LLM이 의미 추론·검색에 사용한다. 카탈로그가 다른 이름을 쓰면(예: textbutton의 'Button Text') 카탈로그 정의를 ground truth로 사용하고, 표준 이름은 hint로만 활용한다.",
      "label": "Badge/Button 등에서 표시할 텍스트",
      "title": "ListItem 등 주요 텍스트",
      "subtitle": "보조 텍스트",
      "description": "설명 텍스트",
      "size": "컴포넌트 크기 토큰. 'small' | 'medium' | 'large' (또는 카탈로그 정의 enum)",
      "tone": "색상/의미 톤. 'success' | 'warning' | 'danger' | 'neutral' | 'info'",
      "icon": "대표 아이콘 이름",
      "leadingIcon": "앞쪽 아이콘 이름",
      "trailingIcon": "뒤쪽 아이콘 이름",
      "image": "이미지 리소스 참조 (Asset.ref 또는 Asset 객체)",
      "isEnabled": "활성화 여부 (boolean)",
      "isSelected": "선택 여부 (boolean)",
      "isLoading": "로딩 여부 (boolean)",
      "accessibilityLabel": "접근성 라벨"
    },
    "CatalogSlots": {
      "_doc": "children을 의미 있는 슬롯에 매핑. 값은 { ref: '<node id>' } (instance slot) 또는 { text: '<value>' } (text slot). 카탈로그가 다른 slot 이름을 쓰면(예: textbutton의 'leading-icon', 'label') 카탈로그 정의가 ground truth, 아래 표준 이름은 의미 매핑 hint.",
      "leading": "leading 영역에 매핑되는 node id",
      "content": "본문/content 영역 node id",
      "title": "title 역할 node id",
      "subtitle": "subtitle 역할 node id",
      "thumbnail": "thumbnail/image 역할 node id",
      "trailing": "trailing 영역 node id",
      "badge": "badge 역할 node id",
      "action": "button/action 역할 node id"
    },
    "Layout": {
      "kind": "'stack' | 'box' | 'overlay' | 'absolute' | 'scroll'",
      "axis": "'vertical' | 'horizontal' (kind='stack'일 때만)",
      "frame": "Frame 타입 참조 (디버깅·오버라이드용, optional)",
      "size": "SizePolicy 타입 참조",
      "positioning": "'flow' | 'absolute'",
      "padding": "Padding 타입 참조",
      "spacing": "children 간 간격 (number)",
      "alignment": "Alignment 타입 참조",
      "constraints": "Constraints 타입 참조",
      "overflow": "'visible' | 'hidden' | 'clip' | 'scroll' | 'ellipsis'",
      "zIndex": "겹침 순서 (number)"
    },
    "Frame": { "x": "px", "y": "px", "width": "px", "height": "px" },
    "SizePolicy": {
      "width": "{ mode: 'fixed' | 'hug' | 'fill', value?: number }",
      "height": "{ mode: 'fixed' | 'hug' | 'fill', value?: number }"
    },
    "Padding": { "top": "px", "right": "px", "bottom": "px", "left": "px" },
    "Alignment": {
      "main": "'start' | 'center' | 'end' | 'spaceBetween' | 'spaceAround' | 'spaceEvenly'",
      "cross": "'start' | 'center' | 'end' | 'stretch' | 'baseline'"
    },
    "Constraints": {
      "minWidth": "number",
      "maxWidth": "number",
      "minHeight": "number",
      "maxHeight": "number",
      "aspectRatio": "number (width/height)",
      "priority": "number"
    },
    "Style": {
      "fills": "Fill 타입 배열",
      "strokes": "Stroke 타입 배열",
      "cornerRadius": "number | { topLeft, topRight, bottomLeft, bottomRight }",
      "effects": "Effect 타입 배열",
      "opacity": "0.0~1.0"
    },
    "Fill": "{ type: 'solid', color: TokenRef } | { type: 'gradient', gradientType: 'linear'|'radial'|'angular', stops: [{ color: TokenRef, position: 0..1 }], angle?: number } | { type: 'image', ref: string, mode: 'fill'|'fit'|'stretch'|'tile' }",
    "Stroke": "{ align?: 'inside'|'center'|'outside', thickness?: number, color?: TokenRef, dashPattern?: number[] }",
    "Effect": "{ type: 'blur'|'background_blur', radius: number } | { type: 'shadow', shadowType: 'inner'|'outer', offset: { x, y }, spread: number, blur: number, color: TokenRef }",
    "TokenRef": "string. 4가지 형식 중 하나. (1) 'token:<dotted.path>' (2) 'hardcoded:<literal>' (3) 'unresolved:<literal>' (4) 'textStyle:<name>' — token_reference_syntax 규칙 참조",
    "Text": {
      "value": "실제 텍스트",
      "textStyle": "TokenRef. 일반적으로 'textStyle:<name>' 또는 'token:typography.<...>'",
      "typography": "Typography 타입 참조 (textStyle 없을 때 폴백 또는 보강)",
      "maxLines": "number",
      "overflow": "'clip' | 'ellipsis' | 'visible'",
      "textAlign": "'left' | 'center' | 'right' | 'justify'",
      "color": "TokenRef (텍스트 색상)"
    },
    "Typography": {
      "fontFamily": "'circular' | 'default' | 폰트명",
      "fontSize": "number (px)",
      "fontWeight": "100~900 또는 'regular'|'medium'|'bold'",
      "lineHeight": "number",
      "letterSpacing": "number"
    },
    "Asset": {
      "kind": "'image' | 'icon' | 'lottie' | 'video'",
      "name": "리소스 이름",
      "ref": "DS 에셋 참조(예: 'icon/size=small(20)')",
      "url": "원격 URL",
      "format": "'png' | 'jpg' | 'svg' | 'webp' | 'json'",
      "alt": "대체 텍스트",
      "tint": "TokenRef (아이콘 컬러)"
    }
  },

  "examples": [
    {
      "title": "기본 textbutton 인스턴스 (다축 variant + slots + 토큰 참조)",
      "dsl": {
        "schemaVersion": "2.0.0",
        "metadata": {
          "generatedAt": "2026-04-27T10:54:13+09:00",
          "generator": "cds-ds@2.0.0",
          "sourceFile": { "fileKey": "ABCDEF1234", "fileName": "Buy CTA", "nodeId": "1:235" },
          "originHash": "sha256:abcd"
        },
        "coordinateSystem": { "unit": "px", "origin": "topLeft", "scope": "relativeToParent", "scale": 1.0 },
        "themes": ["light", "dark"],
        "platform": "ios",
        "dsManifest": {
          "platform": "ios",
          "tokens": ["tokens.color.v1.0", "tokens.size.v1.0", "tokens.typography.v1.0"],
          "components": ["textbutton"]
        },
        "nodes": [
          {
            "id": "n1",
            "type": "component",
            "name": "Buy Button",
            "source": { "figmaNodeId": "1:235", "componentId": "C:100", "instanceId": "I:200" },
            "catalog": {
              "id": "textbutton",
              "componentId": "component:text-button",
              "variant": {
                "Mode": "Default",
                "Type": "Filled",
                "Size": "Large(44)",
                "Button Color": "Default (Gray Ghost 단일컬러)",
                "Status": "Default",
                "Radius": "on"
              },
              "props": {
                "Button Text": "구매하기",
                "Option-Leading": false,
                "Option-Trailing": false,
                "Trailing-Icon": false,
                "Trailing-Text": false
              },
              "slots": {
                "label": { "text": "구매하기" }
              },
              "state": "default"
            },
            "layout": {
              "kind": "box",
              "size": { "width": { "mode": "fill" }, "height": { "mode": "fixed", "value": 44 } },
              "padding": { "top": 12, "right": 16, "bottom": 12, "left": 16 },
              "alignment": { "main": "center", "cross": "center" }
            },
            "style": {
              "fills": [{ "type": "solid", "color": "token:system.color.button.default" }],
              "cornerRadius": 8
            }
          }
        ]
      }
    },
    {
      "title": "leading icon이 있는 textbutton + slot 매핑",
      "dsl_excerpt": {
        "id": "n2",
        "type": "component",
        "name": "Add to cart",
        "catalog": {
          "id": "textbutton",
