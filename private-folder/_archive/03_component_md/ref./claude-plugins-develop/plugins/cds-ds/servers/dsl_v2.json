          "props": { "Button Text": "장바구니", "Option-Leading": true },
          "slots": {
            "leading-icon": { "ref": "n2_icon" },
            "label": { "text": "장바구니" }
          }
        },
        "children": [
          {
            "id": "n2_icon",
            "type": "icon",
            "name": "cart",
            "asset": { "kind": "icon", "ref": "Icon/size=small(20)", "format": "svg", "tint": "token:system.color.label.primary" }
          }
        ]
      }
    },
    {
      "title": "토큰 매칭 실패 + 하드코딩 + 텍스트 스타일",
      "dsl_excerpt": {
        "id": "n3",
        "type": "text",
        "name": "Caption",
