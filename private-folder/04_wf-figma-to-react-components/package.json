{
  "name": "@chord-ds/components",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/components.css"
  },
  "scripts": {
    "dev": "vite",
    "prestorybook": "npm run tokens:build",
    "storybook": "npm run build-storybook && python3 -m http.server 7008 -d storybook-static",
    "prebuild-storybook": "npm run tokens:build",
    "build-storybook": "storybook build",
    "tokens:build": "node scripts/build-tokens.mjs",
    "icons:sync-medium": "node scripts/sync-medium-icons.mjs",
    "icons:generate": "node scripts/generate-chord-icons.mjs",
    "knowledge:audit": "node scripts/audit-knowledge-layer.mjs",
    "rules:audit": "node scripts/audit-workflow-rules.mjs",
    "visual:baseline": "node scripts/visual-diff.mjs baseline",
    "visual:diff": "node scripts/visual-diff.mjs diff",
    "visual:test": "npm run build-storybook && npm run visual:diff",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "npm run tokens:build && tsc --noEmit && vite build",
    "build:lib": "npm run tokens:build && vite build --config vite.lib.config.ts"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "lottie-react": "^2.4.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.4",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.2.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "storybook": "8.6.18",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.0.15"
  }
}
