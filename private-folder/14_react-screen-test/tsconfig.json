{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@chord-ds/components": ["../04_wf-figma-to-react-components/src/components/index.ts"],
      "@chord-ds/components/*": ["../04_wf-figma-to-react-components/src/*"]
    }
  },
  "include": ["src", "tests"]
}
