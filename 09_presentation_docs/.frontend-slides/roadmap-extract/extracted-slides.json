  {
    "number": 6,
    "title": "",
    "content": [
      {
        "type": "text",
        "content": "2026 Goal - 2 Point"
      },
      {
        "type": "text",
        "content": "\uc0ac\uc6a9\uc790 \ub9e5\ub77d > \uc77c\uad00\uc131"
      },
      {
        "type": "text",
        "content": "\uc911\uc559 \ud1b5\uc81c > \uc790\uc728\uc801 \ud310\ub2e8"
      },
      {
        "type": "text",
        "content": "Core System \uac15\ud654"
      },
      {
        "type": "text",
        "content": "Local System \uc704\uc784"
      },
      {
        "type": "text",
        "content": "\ub2e4\uc591\uc131 > \ube0c\ub79c\ub4dc \ubcf4\uc774\uc2a4"
      },
      {
        "type": "text",
        "content": "\ud655\uc7a5\uc131 > \ubb38\uc81c \ud574\uacb0"
      },
      {
        "type": "text",
        "content": "\ubaa8\ub4e0 \ud654\uba74\uc5d0 \ub3d9\uc77c\ud55c \uaddc\uce59\uc744 \uc801\uc6a9\ud558\uae30\ubcf4\ub2e4 \uac01 \uae30\ub2a5\uc758 \ud2b9\uc218\ud55c \uc0c1\ud669\uacfc \ub9e5\ub77d\uc744 \ub354 \uc874\uc911\ud55c\ub2e4."
      },
      {
        "type": "text",
        "content": "\ub514\uc790\uc774\ub108\uc758 \uac1c\ubcc4 \ud310\ub2e8\ubcf4\ub2e4\ub294 \uc2dc\uc2a4\ud15c \ub2f4\ub2f9\uacfc\uc758 \uc2f1\ud06c\ub97c \ud1b5\ud55c \uad00\ub9ac\ub97c \uc6b0\uc120\ud55c\ub2e4."
      },
      {
        "type": "text",
        "content": "\uc704\ubc84\uc2a4 \ube0c\ub79c\ub4dc\uc758 \ud1b5\uc77c\uac10\ubcf4\ub2e4\ub294 \uc785\uc810\ud55c \uac01 \uc544\ud2f0\uc2a4\ud2b8(IP)\uc758 \uace0\uc720\ud55c \ub9e4\ub825\uacfc \ub2e4\uc591\uc131\uc744 \uc0b4\ub9ac\ub294 \ub370 \uc9d1\uc911\ud55c\ub2e4."
      },
      {
        "type": "text",
        "content": "\ub2f9\uc7a5\uc758 \ubd88\ud3b8 \ud574\uacb0\uc5d0 \ub9e4\ubab0\ub418\uae30\ubcf4\ub2e4 \ub098\uc911\uc5d0 \uc5b4\ub5a4 \uae30\ub2a5\uc774 \ubd99\uc5b4\ub3c4 \ubb38\uc81c\uc5c6\ub3c4\ub85d \ubbf8\ub798\ub97c \uc124\uacc4\ud558\ub294 \ud655\uc7a5\uc131\uc744 \uc6b0\uc120\ud55c\ub2e4."
      },
      {
        "type": "text",
        "content": "\uc704\ubc84\uc2a4 \ub514\uc790\uc778 \uc2dc\uc2a4\ud15c \uc6cc\ud06c\uc0f5\uc744 \ud1b5\ud574 \ub3c4\ucd9c\ud55c \ud0a4\uc6cc\ub4dc\ub97c \uae30\ubc18\uc73c\ub85c \uc124\uc815"
      }
    ],
