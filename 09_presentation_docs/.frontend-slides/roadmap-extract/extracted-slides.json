  {
    "number": 3,
    "title": "",
    "content": [
      {
        "type": "text",
        "content": "2026 Chord Design System"
      },
      {
        "type": "text",
        "content": "Sparkbox\uc758 \ub514\uc790\uc778 \uc2dc\uc2a4\ud15c \uc131\uc219\ub3c4 5\ub2e8\uacc4"
      },
      {
        "type": "text",
        "content": "1\ub2e8\uacc4: \uc2dc\uc791 \ub2e8\uacc4"
      },
      {
        "type": "text",
        "content": "2\ub2e8\uacc4: \uad6c\ucd95 \ub2e8\uacc4"
      },
      {
        "type": "text",
        "content": "3\ub2e8\uacc4: \ud655\uc0b0 \ub2e8\uacc4"
      },
      {
        "type": "text",
        "content": "4\ub2e8\uacc4: \uc9c0\uc18d \ub2e8\uacc4"
      },
      {
        "type": "text",
        "content": "5\ub2e8\uacc4: \uc9c4\ud654 \ub2e8\uacc4"
      },
      {
        "type": "text",
        "content": "\ub514\uc790\uc778 \uc2dc\uc2a4\ud15c\uc758 \ud544\uc694\uc131\uc744 \uc778\uc2dd\ud558\uace0 \ud30c\ud3b8\ud654\ub41c UI \uc694\uc18c\ub4e4\uc744 \ubaa8\uc73c\uae30 \uc2dc\uc791\ud558\ub294 \ub2e8\uacc4\uc785\ub2c8\ub2e4.\n\ud2b9\uc9d5: \uacf5\uc2dd\uc801\uc778 \uc2dc\uc2a4\ud15c\uc774\ub77c\uae30\ubcf4\ub2e4 '\uc2a4\ud0c0\uc77c \uac00\uc774\ub4dc'\ub098 'UI \ud0a4\ud2b8'\uc5d0 \uac00\uae5d\uc2b5\ub2c8\ub2e4.\n\uc0c1\ud0dc: \ud2b9\uc815 \ub514\uc790\uc774\ub108\uc758 \ub85c\uceec \ud30c\uc77c\uc5d0 \uc874\uc7ac\ud558\uac70\ub098, \ubb38\uc11c\ud654\uac00 \uac70\uc758 \ub418\uc5b4 \uc788\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4."
      },
      {
        "type": "text",
        "content": "\ubcf8\uaca9\uc801\uc73c\ub85c \ucef4\ud3ec\ub10c\ud2b8\ub97c \uc124\uacc4\ud558\uace0 \ucf54\ub4dc\ub85c \uad6c\ud604\ud558\ub294 \ub2e8\uacc4\uc785\ub2c8\ub2e4.\n\ud2b9\uc9d5: \uc0c9\uc0c1, \ud0c0\uc774\ud3ec\uadf8\ub798\ud53c, \ubc84\ud2bc \ub4f1 \uae30\ucd08 \uc790\uc0b0\uc774 \uc815\uc758\ub429\ub2c8\ub2e4.\n\uc0c1\ud0dc: \uc2dc\uc2a4\ud15c\uc744 \uc804\ub2f4\ud558\uac70\ub098 \ubd80\ubd84\uc801\uc73c\ub85c \ub2f4\ub2f9\ud558\ub294 \ud300\uc774 \uc0dd\uae30\uae30 \uc2dc\uc791\ud558\uba70, \uae30\uc220 \uc2a4\ud0dd\uc774 \uacb0\uc815\ub429\ub2c8\ub2e4."
      },
      {
        "type": "text",
        "content": "\ub9cc\ub4e4\uc5b4\uc9c4 \uc2dc\uc2a4\ud15c\uc744 \uc2e4\uc81c \uc81c\ud488 \ud300\ub4e4\uc774 \uac00\uc838\ub2e4 \uc4f0\uae30 \uc2dc\uc791\ud558\ub294 \ub2e8\uacc4\uc785\ub2c8\ub2e4.\n\ud2b9\uc9d5: \"\uc774\uac78 \uc65c \uc368\uc57c \ud558\uc8e0?\"\ub77c\ub294 \uc9c8\ubb38\uc5d0 \ub2f5\ud574\uc57c \ud558\ub294 \uc2dc\uae30\uc785\ub2c8\ub2e4. \uc0ac\uc6a9\ubc95\uc5d0 \ub300\ud55c \ubb38\uc11c\ud654\uac00 \uc911\uc694\ud574\uc9d1\ub2c8\ub2e4.\n\uc0c1\ud0dc: \uc5ec\ub7ec \ud504\ub85c\uc81d\ud2b8\uc5d0\uc11c \uacf5\ud1b5\ub41c \ub77c\uc774\ube0c\ub7ec\ub9ac\ub97c \ucc38\uc870\ud558\uba70, \uc77c\uad00\uc131\uc774 \ub208\uc5d0 \ubcf4\uc774\uae30 \uc2dc\uc791\ud569\ub2c8\ub2e4."
      },
      {
        "type": "text",
        "content": "\uc2dc\uc2a4\ud15c\uc774 \uc77c\ud68c\uc131 \ud504\ub85c\uc81d\ud2b8\uac00 \uc544\ub2c8\ub77c '\ud558\ub098\uc758 \uc81c\ud488'\uc73c\ub85c \ucde8\uae09\ubc1b\ub294 \ub2e8\uacc4\uc785\ub2c8\ub2e4.\n\ud2b9\uc9d5: \uc0c8\ub85c\uc6b4 \uc694\uad6c\uc0ac\ud56d\uc744 \ubc18\uc601\ud558\ub294 '\uac70\ubc84\ub10c\uc2a4' \ud504\ub85c\uc138\uc2a4\uac00 \uc815\ub9bd\ub429\ub2c8\ub2e4.\n\uc0c1\ud0dc: \ubc84\uadf8 \uc218\uc815, \uc5c5\ub370\uc774\ud2b8 \ubc30\ud3ec \uc8fc\uae30, \ubc84\uc804 \uad00\ub9ac\uac00 \uccb4\uacc4\uc801\uc73c\ub85c \uc774\ub8e8\uc5b4\uc9d1\ub2c8\ub2e4."
      },
      {
        "type": "text",
        "content": "\ub514\uc790\uc778 \uc2dc\uc2a4\ud15c\uc774 \uc870\uc9c1\uc758 \ubb38\ud654\ub85c \uc790\ub9ac \uc7a1\uace0, \uc804\ub7b5\uc801\uc778 \uc790\uc0b0\uc774 \ub418\ub294 \ucd5c\uc885 \ub2e8\uacc4\uc785\ub2c8\ub2e4.\n\ud2b9\uc9d5: \uc2dc\uc2a4\ud15c\uc774 \uc2a4\uc2a4\ub85c \ubcc0\ud654\uc5d0 \uc801\uc751\ud569\ub2c8\ub2e4. \uc0c8\ub85c\uc6b4 \uae30\uc220(\uc608: \uc0c8\ub85c\uc6b4 \ud504\ub808\uc784\uc6cc\ud06c \uc804\ud658)\uc774 \ub3c4\uc785\ub418\uc5b4\ub3c4 \uc720\uc5f0\ud558\uac8c \ub300\ucc98\ud569\ub2c8\ub2e4.\n\uc0c1\ud0dc: \uc870\uc9c1 \uc804\uccb4\uac00 \uc2dc\uc2a4\ud15c\uc758 \uac00\uce58\ub97c \uc774\ud574\ud558\uba70, \uae30\uc5ec \ubaa8\ub378\uc774 \ud65c\uc131\ud654\ub418\uc5b4 \uc120\uc21c\ud658 \uad6c\uc870\ub97c \uc774\ub8f9\ub2c8\ub2e4."
      },
      {
        "type": "text",
        "content": "2023-2024"
      },
      {
        "type": "text",
        "content": "2024-2025"
      },
      {
        "type": "text",
        "content": "2026~"
      }
    ],
