  {
    "number": 7,
    "title": "",
    "content": [
      {
        "type": "text",
        "content": "2026 Roadmap - Key Task"
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
        "content": "Local System \uc704\uc784\uc744 \uc704\ud55c\n\ub514\uc790\uc778 \uc2dc\uc2a4\ud15c \uae30\uc5ec \ud504\ub85c\uc138\uc2a4"
      },
      {
        "type": "text",
        "content": "\uc2dc\uc2a4\ud15c \ub2f4\ub2f9 \ub514\uc790\uc774\ub108\uc640 \uc0ac\uc6a9\uc790(\ud504\ub85c\ub355\ud2b8 \ub514\uc790\uc774\ub108) \uac04\uc758 \uac04\uadf9\uc744 \uc904\uc5ec\uc57c \ud569\ub2c8\ub2e4.\n\uc0c8\ub85c\uc6b4 \ucef4\ud3ec\ub10c\ud2b8\uac00 \ud544\uc694\ud558\uac70\ub098 \uae30\uc874 \uac83\uc774 \uc218\uc815\ub418\uc5b4\uc57c \ud560 \ub54c, \ub204\uad6c\ub098 \uc81c\uc548\ud558\uace0 \uc2dc\uc2a4\ud15c\uc5d0 \ubc18\uc601\ub418\ub294 \uae30\uc5ec \ud504\ub85c\uc138\uc2a4\ub97c \uc6b4\uc601\ud558\uace0\uc790 \ud569\ub2c8\ub2e4.\n\uc0ac\ub840 : Shopify\uc758 Polaris\ub294 \ub204\uad6c\ub098 \uc2dc\uc2a4\ud15c \uac1c\uc120\uc744 \uc81c\uc548\ud560 \uc218 \uc788\ub294 \uba85\ud655\ud55c \ucc44\ub110\uc744 \uc6b4\uc601\ud558\uc5ec '\ubaa8\ub450\uc758 \uc2dc\uc2a4\ud15c'\uc774\ub77c\ub294 \uc778\uc2dd\uc744 \uc2ec\uc5b4\uc90d\ub2c8\ub2e4."
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
        "content": "Core System \uac15\ud654\ub97c \uc704\ud55c\nAI \uc5d0\uc774\uc804\ud2b8 \uc81c\uc791"
      },
      {
        "type": "text",
        "content": "\ub514\uc790\uc778 \uc2dc\uc2a4\ud15c\uc744 AI\uc5d0\uac8c \ud559\uc2b5\uc2dc\ud0a4\uace0, \uadf8 \uae30\ubc18\uc73c\ub85c \ucee4\uc2a4\ud140 \uc2ac\ub86f\uc744 \uc790\uc5f0\uc5b4\ub85c \uc0dd\uc131\ud558\uc5ec \uad00\ub9ac\ud560 \uc218 \uc788\uac8c \ud569\ub2c8\ub2e4. \uac04\ub2e8\ud55c UX\uc758 \uacbd\uc6b0 \ucee4\uc2a4\ud140 \uc2ac\ub86f \uc0dd\uc131 \uc5d0\uc774\uc804\ud2b8\ub97c \ud1b5\ud574 \ub514\uc790\uc778\uacfc \uac1c\ubc1c \uacf5\uc218\ub97c \ub35c \ub4e4\uc774\uace0\ub3c4 \ubc30\ud3ec\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\uc0ac\ub840 : \ud300\uc2a4\ud30c\ub974\ud0c0 - \ub514\uc790\uc778 \uc2dc\uc2a4\ud15c\uc774 AI\ub97c \ub9cc\ub0ac\uc744\ub54c (MCP \ud65c\uc6a9\uae30)"
      },
      {
        "type": "text",
        "content": ""
      },
      {
        "type": "text",
        "content": "\ud575\uc2ec\uacfc\uc81c (\uc544\uc774\ub514\uc5b4 \ub3c4\ucd9c\uc911)"
      }
    ],
